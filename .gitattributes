# ============================================================
# GYM SYLLA — .gitattributes
# Normalise les fins de ligne pour éviter le bruit dans les diffs
# entre collaborateurs (Windows / Linux / macOS)
# ============================================================

# Par défaut : normaliser tous les fichiers texte en LF dans le dépôt
* text=auto eol=lf

# ── Code source ─────────────────────────────────────────────
*.php      text eol=lf
*.ts       text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.tsx      text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.json     text eol=lf
*.sql      text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.env.example text eol=lf

# ── Scripts ─────────────────────────────────────────────────
*.sh       text eol=lf
*.bash     text eol=lf

# Scripts Windows : garder CRLF (sinon ils peuvent casser)
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# ── Fichiers binaires (ne jamais modifier) ──────────────────
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      text eol=lf
*.pdf      binary
*.zip      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary
*.mp4      binary
*.webp     binary