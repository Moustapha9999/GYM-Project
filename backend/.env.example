# ── Application ─────────────────────────────────────────────
APP_NAME=GYM SYLLA API
APP_ENV=development
API_V1_PREFIX=/api/v1

# ── Base de données ─────────────────────────────────────────
DATABASE_URL=postgresql://gym_user:CHANGE_ME@localhost:5432/gym_sylla

# ── Sécurité JWT ────────────────────────────────────────────
# Générer une clé aléatoire d'au moins 32 caractères (ex: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET_KEY_32_CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Métier ──────────────────────────────────────────────────
DEVISE=MRU
TARIF_SEANCE_JOURNALIERE=50

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200

# ── Notifications (micro-service WhatsApp) ───────────────────
NOTIFICATION_SERVICE_URL=http://localhost:3001
# Même valeur que API_SECRET du micro-service notification-service
NOTIFICATION_API_SECRET=CHANGE_ME_SHARED_SECRET_MIN_16_CHARS
