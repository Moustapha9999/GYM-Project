# ── Application ─────────────────────────────────────────────
APP_NAME=GYM SYLLA API
APP_ENV=development
API_V1_PREFIX=/api/v1

# ── Base de données ─────────────────────────────────────────
# Machine A (serveur DB local) :
DATABASE_URL=postgresql://gym_user:gym_password_dev_only@localhost:5432/gym_sylla
#
# Machines B/C (poste client → IP du serveur PostgreSQL) :
# DATABASE_URL=postgresql://gym_user:gym_password_dev_only@192.168.1.10:5432/gym_sylla

# ── Sécurité JWT ────────────────────────────────────────────
# Identique sur TOUS les postes (sinon les tokens JWT ne sont pas valides entre machines)
# Générer : openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET_KEY_32_CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Métier ──────────────────────────────────────────────────
DEVISE=MRU
TARIF_SEANCE_JOURNALIERE=50

# ── CORS ────────────────────────────────────────────────────
# Origines explicites (séparées par des virgules) :
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
#
# En développement multi-postes : autorise aussi http://192.168.x.x:PORT
CORS_ALLOW_LAN=true

# ── Notifications (micro-service WhatsApp) ───────────────────
# Machine hôte du service WhatsApp (souvent la machine A) :
NOTIFICATION_SERVICE_URL=http://localhost:3001
# Depuis un autre poste : NOTIFICATION_SERVICE_URL=http://192.168.1.10:3001
#
# Même valeur que API_SECRET du micro-service notification-service
NOTIFICATION_API_SECRET=CHANGE_ME_SHARED_SECRET_MIN_16_CHARS
