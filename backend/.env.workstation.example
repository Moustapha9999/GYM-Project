# Copier vers backend/.env sur les postes B/C (réception, manager, etc.)
# cp backend/.env.workstation.example backend/.env
#
# IP LAN de la machine A (serveur PostgreSQL) — voir scripts/machine-a-ip.conf

APP_NAME=GYM SYLLA API
APP_ENV=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql://gym_user:gym_password_dev_only@192.168.100.6:5432/gym_sylla

# Copier la MÊME SECRET_KEY que sur la machine A
SECRET_KEY=CHANGE_ME_SAME_AS_DB_SERVER
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

DEVISE=MRU
TARIF_SEANCE_JOURNALIERE=50

CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOW_LAN=true

# IP de la machine qui héberge le service WhatsApp (souvent machine A)
NOTIFICATION_SERVICE_URL=http://192.168.100.6:3001
NOTIFICATION_API_SECRET=CHANGE_ME_SHARED_SECRET_MIN_16_CHARS
